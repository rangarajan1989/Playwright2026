pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/playwright:v1.49.0-noble' // Match this to your project's Playwright version
            args '--entrypoint='
        }
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                // Installs your node modules (including Playwright)
                sh 'npm ci'
            }
        }

        stage('Run Playwright Tests') {
            steps {
                // Executes the tests. The CI=true env variable ensures proper logging
                sh 'CI=true npx playwright test'
            }
        }
    }

    post {
        always {
            // Archives the HTML report and screenshots so you can view them in Jenkins
            publishHTML(target: [
                alwaysLinkToLastBuild: true,
                keepAll: true,
                reportDir: 'playwright-report',
                reportFiles: 'index.html',
                reportName: 'Playwright HTML Report'
            ])
            
            // Optional: If you generate JUnit XML reports, uncomment the line below
            // junit 'playwright-report/results.xml'
        }
    }
}